# Lima config for the Playground executor VM.
# The VM is recreated on every `playground run`.

images:
  - location: "https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-arm64.img"
    arch: "aarch64"
  - location: "https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-amd64.img"
    arch: "x86_64"

vmType: "vz"
mountType: "virtiofs"

cpus: 4
memory: "64GiB"
disk: "60GiB"

mounts:
  - location: "__PLAYGROUND_ROOT__"
    mountPoint: "/opt/playground"
    writable: false
  - location: "__FACULTIES_ROOT__"
    mountPoint: "/opt/faculties"
    writable: true
  - location: "__PILE_ROOT__"
    mountPoint: "/pile"
    writable: true
  - location: "__WORKSPACE_ROOT__"
    mountPoint: "__VM_ROOT__"
    writable: true

provision:
  - mode: system
    script: |
      set -eu
      echo "[playground] system provision start"
      apt-get update
      apt-get install -y --no-install-recommends ca-certificates curl build-essential
      ln -sfn __PILE_PATH__ /self.pile
      ln -sfn /self.pile __VM_ROOT__/self.pile
      cat >/etc/systemd/system/playground-exec.service <<'SERVICE'
      [Unit]
      Description=Playground Exec Worker
      After=network-online.target

      [Service]
      User=__VM_USER__
      Group=__VM_USER__
      WorkingDirectory=__VM_ROOT__
      ExecStart=/bin/bash -lc 'source $HOME/.cargo/env >/dev/null 2>&1 || true; CARGO_TARGET_DIR=__VM_ROOT__/target cargo run --release --manifest-path /opt/playground/Cargo.toml --no-default-features -- exec --pile /self.pile'
      Restart=always
      RestartSec=2

      [Install]
      WantedBy=multi-user.target
      SERVICE
      systemctl daemon-reload
      echo "[playground] system provision done"
  - mode: user
    script: |
      set -eu
      echo "[playground] user provision start"
      if [ ! -x "$HOME/.cargo/bin/rustc" ]; then
        echo "[playground] installing rustup"
        curl https://sh.rustup.rs -sSf | sh -s -- -y
      fi
      source "$HOME/.cargo/env" >/dev/null 2>&1 || true
      rustup target add wasm32-unknown-unknown
      if ! command -v rust-script >/dev/null 2>&1; then
        echo "[playground] installing rust-script"
        cargo install --locked rust-script
      fi
      # Put faculties on PATH for direct invocation (e.g. compass.rs list).
      if ! grep -q '/opt/faculties' "$HOME/.bashrc" 2>/dev/null; then
        echo 'export PATH="/opt/faculties:$PATH"' >> "$HOME/.bashrc"
      fi
      # Warm rust-script cache for each faculty so first real invocation is fast.
      echo "[playground] warming rust-script cache for faculties"
      for f in /opt/faculties/*.rs; do
        "$f" --help >/dev/null 2>&1 || true
      done
      echo "[playground] user provision done"
      echo "[playground] starting exec service"
      sudo systemctl enable playground-exec.service
      sudo systemctl restart playground-exec.service

# Lima config for a Playground SANDBOX-PROVIDER session VM.
#
# Unlike scripts/lima.yaml.tmpl (the `playground run` template, which starts a
# systemd service that polls the pile), this template provisions a plain shell
# VM that the host drives with `limactl shell <instance> -- sh -lc <cmd>`.
#
# The pile is mounted WRITABLE (append is required). A guest-side `chattr +a`
# (injected by src/sandbox/lima.rs::guest_pile_setup()) *attempts* append-only
# enforcement, but virtiofs does not support inode flags so it is a no-op today
# (see that fn's doc for the measurement + the follow-on options). Sessions are
# currently trusted not to truncate their own pile, not prevented from it.
#
# Faculties (wiki/compass/orient/message/files/teams/... CLI binaries) are staged
# by mounting a host directory of prebuilt Linux-aarch64 faculty binaries at
# /opt/faculties (read-only) and putting it on PATH, with PILE pointing at the
# mounted pile. So `compass list` / `wiki search X` run in a session resolve and
# operate on the session's mounted pile. src/sandbox/lima.rs::render_config fills
# the placeholders below (a no-op when no faculties bundle is configured).
#
# NOTE: placeholder tokens are substituted by a GLOBAL string replace, so the
# `__TOKEN__` names must never appear in this prose or they would be clobbered
# here too.

images:
  - location: "https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-arm64.img"
    arch: "aarch64"
  - location: "https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-amd64.img"
    arch: "x86_64"

vmType: "vz"
mountType: "virtiofs"

cpus: 4
memory: "8GiB"
disk: "30GiB"

mounts:
  - location: "__PILE_ROOT__"
    mountPoint: "/pile"
    writable: true
__FACULTIES_MOUNT__

provision:
  - mode: system
    script: |
      set -eu
      echo "[playground-sandbox] system provision start"
      apt-get update
      # libasound2: the faculty binaries link alsa-sys (via rodio, used for
      # audio device enumeration), so the runtime ALSA lib must be present or
      # they fail to load. e2fsprogs provides chattr for the append-only pile.
      apt-get install -y --no-install-recommends ca-certificates curl e2fsprogs libasound2
      ln -sfn __PILE_PATH__ /self.pile
      echo "[playground-sandbox] system provision done"
  - mode: system
    script: |
      set -eu
      # Seed session environment for every login shell (`sh -l` sources this).
      # PILE (mounted pile guest path) + the faculties dir on PATH are seeded
      # here too, so a faculty CLI run in any session resolves and operates on
      # the session's mounted pile.
      cat >/etc/profile.d/playground-session.sh <<'ENVEOF'
      __FACULTIES_PATH_EXPORT__
      export PILE='__PILE_PATH__'
      __SESSION_ENV__
      ENVEOF
  - mode: user
    script: |
      set -eu
      echo "[playground-sandbox] user provision start"
      # Make the pile append-only inside the guest. Append (commits) keeps
      # working; truncation/replacement is refused with EPERM.
      __GUEST_PILE_SETUP__
      echo "[playground-sandbox] user provision done"
